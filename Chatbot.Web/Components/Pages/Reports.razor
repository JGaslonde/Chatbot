@page "/reports"
@using Chatbot.Core.Models.Requests
@using Chatbot.Core.Models.Responses
@using Chatbot.Web.Services
@inject IReportingManagementService ReportingService
@inject ILogger<Reports> Logger
@attribute [Authorize]

<PageTitle>Reports Management</PageTitle>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Reports Management</h2>
            <p class="text-muted">Schedule and generate conversation reports</p>
        </div>
        <div class="col-md-4 text-end">
            <button class="btn btn-primary" @onclick="ShowCreateForm">+ New Report</button>
        </div>
    </div>

    @if (showCreateForm)
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5>Create Scheduled Report</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label">Report Name</label>
                            <input type="text" class="form-control" @bind="newReportName"
                                   placeholder="Monthly Activity Report" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Report Type</label>
                            <select class="form-control" @bind="newReportType">
                                <option value="conversation_summary">Conversation Summary</option>
                                <option value="user_activity">User Activity</option>
                                <option value="sentiment_analysis">Sentiment Analysis</option>
                                <option value="performance_metrics">Performance Metrics</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Frequency</label>
                            <select class="form-control" @bind="newReportFrequency">
                                <option value="daily">Daily</option>
                                <option value="weekly">Weekly</option>
                                <option value="monthly">Monthly</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Recipient Email (Optional)</label>
                            <input type="email" class="form-control" @bind="newReportEmail"
                                   placeholder="user@example.com" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description (Optional)</label>
                            <textarea class="form-control" @bind="newReportDescription"
                                      placeholder="Add notes about this report"></textarea>
                        </div>
                    </div>
                </div>
                <div class="btn-group">
                    <button class="btn btn-success" @onclick="CreateReport">Create Report</button>
                    <button class="btn btn-secondary" @onclick="CancelCreateForm">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (reports == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading reports...</span>
            </div>
        </div>
    }
    else if (reports.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No reports scheduled yet. Create your first report to get started.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Report Name</th>
                        <th>Type</th>
                        <th>Frequency</th>
                        <th>Last Generated</th>
                        <th>Next Generation</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in reports)
                    {
                        <tr>
                            <td>@report.Name</td>
                            <td>@report.ReportType</td>
                            <td><span class="badge bg-info">@report.Frequency</span></td>
                            <td>@(report.LastGeneratedAt?.ToString("g") ?? "Never")</td>
                            <td>@(report.NextGeneratedAt?.ToString("g") ?? "Pending")</td>
                            <td>
                                @if (report.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-info"
                                        @onclick="() => GenerateReport(report.Id, report.Name)">Generate</button>
                                <button class="btn btn-sm btn-warning" @onclick="() => EditReport(report)">Edit</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteReport(report.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (message != null)
    {
        <div class="alert alert-@messageType alert-dismissible fade show" role="alert">
            @message
            <button type="button" class="btn-close" @onclick="() => message = null"></button>
        </div>
    }
</div>

@code {
    private List<ScheduledReportDto>? reports;
    private string? newReportName = "";
    private string? newReportDescription = "";
    private string? newReportType = "conversation_summary";
    private string? newReportFrequency = "weekly";
    private string? newReportEmail = "";
    private bool showCreateForm = false;
    private string? message;
    private string messageType = "info";

    protected override async Task OnInitializedAsync()
    {
        await LoadReports();
    }

    private async Task LoadReports()
    {
        try
        {
            reports = await ReportingService.GetReportsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error loading reports: {ex.Message}");
            message = "Failed to load reports";
            messageType = "danger";
        }
    }

    private void ShowCreateForm()
    {
        newReportName = "";
        newReportDescription = "";
        newReportType = "conversation_summary";
        newReportFrequency = "weekly";
        newReportEmail = "";
        showCreateForm = true;
    }

    private void CancelCreateForm()
    {
        showCreateForm = false;
    }

    private async Task CreateReport()
    {
        if (string.IsNullOrWhiteSpace(newReportName))
        {
            message = "Report name is required";
            messageType = "warning";
            return;
        }

        var request = new ScheduledReportRequest(
            Name: newReportName,
            Description: newReportDescription,
            ReportType: newReportType ?? "conversation_summary",
            Frequency: newReportFrequency ?? "weekly",
            RecipientEmail: newReportEmail
        );

        var success = await ReportingService.CreateScheduledReportAsync(request) != null;
        if (success)
        {
            message = "Report scheduled successfully";
            messageType = "success";
            showCreateForm = false;
            await LoadReports();
        }
        else
        {
            message = "Failed to create report";
            messageType = "danger";
        }
    }

    private async Task GenerateReport(int reportId, string reportName)
    {
        try
        {
            var data = await ReportingService.GenerateReportAsync(reportId, "pdf");
            if (data != null)
            {
                // In a real app, use JS interop to trigger file download
                message = $"Report generated: {reportName}";
                messageType = "success";
            }
            else
            {
                message = "Failed to generate report";
                messageType = "danger";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error generating report: {ex.Message}");
            message = "An error occurred while generating the report";
            messageType = "danger";
        }
    }

    private void EditReport(ScheduledReportDto report)
    {
        message = "Edit functionality coming soon";
        messageType = "info";
    }

    private async Task DeleteReport(int reportId)
    {
        if (!await ConfirmAsync("Are you sure you want to delete this report?"))
            return;

        var success = await ReportingService.DeleteScheduledReportAsync(reportId);
        if (success)
        {
            message = "Report deleted successfully";
            messageType = "success";
            await LoadReports();
        }
        else
        {
            message = "Failed to delete report";
            messageType = "danger";
        }
    }

    private async Task<bool> ConfirmAsync(string message)
    {
        return await Task.FromResult(true);
    }
}