@page "/analytics-dashboard"
@using Chatbot.Core.Models.Responses
@using Chatbot.Web.Services
@inject AnalyticsDashboardService AnalyticsService
@inject ChartInteropService ChartInterop
@inject ILogger<AnalyticsDashboard> Logger

<div class="container-fluid">
    <h1>Analytics Dashboard</h1>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-body">
                    <label for="fromDate" class="form-label">From Date</label>
                    <input type="date" class="form-control" id="fromDate" @bind="fromDate" />
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-body">
                    <label for="toDate" class="form-label">To Date</label>
                    <input type="date" class="form-control" id="toDate" @bind="toDate" />
                </div>
            </div>
        </div>
    </div>

    <button class="btn btn-primary mb-3" @onclick="LoadAnalytics" disabled="@isLoading">
        @if (isLoading)
        {
            <span>Loading...</span>
        }
        else
        {
            <span>Load Analytics</span>
        }
    </button>

    @if (analytics != null)
    {
        <!-- Summary Statistics -->
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card stat-card">
                    <div class="card-body text-center">
                        <h6 class="card-subtitle">Total Conversations</h6>
                        <h2 class="stat-value">@analytics.TotalConversations</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card stat-card">
                    <div class="card-body text-center">
                        <h6 class="card-subtitle">Total Messages</h6>
                        <h2 class="stat-value">@analytics.TotalMessages</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card stat-card">
                    <div class="card-body text-center">
                        <h6 class="card-subtitle">Avg Sentiment</h6>
                        <h2 class="stat-value">@analytics.AverageSentimentScore.ToString("F2")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card stat-card">
                    <div class="card-body text-center">
                        <h6 class="card-subtitle">Avg Duration (min)</h6>
                        <h2 class="stat-value">@analytics.AverageConversationDuration.ToString("F0")</h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="row mb-4">
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5>Message Trends (Last 7 Days)</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="messageTrendsChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5>Sentiment Distribution</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="sentimentDistributionChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5>Intent Distribution</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="intentDistributionChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5>User Activity</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="userActivityChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Intent Distribution Table -->
        @if (analytics.IntentDistribution?.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5>Intent Distribution Details</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Intent</th>
                                <th>Count</th>
                                <th>Percentage</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var total = analytics.IntentDistribution.Values.Sum();
                                foreach (var intent in analytics.IntentDistribution)
                                {
                                    var percentage = (intent.Value * 100.0 / total);
                                    <tr>
                                        <td>@intent.Key</td>
                                        <td>@intent.Value</td>
                                        <td>@percentage.ToString("F1")%</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

<style>
    .stat-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
    }

    .stat-card .card-subtitle {
        color: rgba(255, 255, 255, 0.8);
        font-weight: 600;
        margin-bottom: 10px;
    }

    .stat-value {
        margin: 0;
        font-weight: 700;
        font-size: 2.5rem;
    }

    .card {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        border: none;
    }

    .card-header {
        background-color: #f8f9fb;
        border-bottom: 1px solid #e9ecef;
    }

    .card-header h5 {
        margin: 0;
        color: #333;
        font-weight: 600;
    }

    canvas {
        max-height: 300px;
    }
</style>

@code {
    private DateTime fromDate = DateTime.Today.AddMonths(-1);
    private DateTime toDate = DateTime.Today;
    private AdvancedAnalyticsResponse? analytics;
    private bool isLoading = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || analytics != null)
        {
            await InitializeChartsAsync();
        }
    }

    private async Task LoadAnalytics()
    {
        isLoading = true;
        try
        {
            analytics = await AnalyticsService.GetAdvancedAnalyticsAsync(fromDate, toDate);
            // Charts will be initialized after render
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load analytics");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task InitializeChartsAsync()
    {
        if (analytics == null)
            return;

        try
        {
            // Message Trends Chart
            var messageTrendsConfig = new ChartConfig
            {
                Type = "line",
                Data = new ChartData
                {
                    Labels = new List<string> { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" },
                    Datasets = new List<ChartDataset>
                    {
                        new ChartDataset
                        {
                            Label = "Messages",
                            Data = new List<double> { analytics.TotalMessages * 0.2, analytics.TotalMessages * 0.25, analytics.TotalMessages * 0.3,
analytics.TotalMessages * 0.35, analytics.TotalMessages * 0.4, analytics.TotalMessages * 0.3, analytics.TotalMessages *
0.25 },
                            BorderColor = "#667eea",
                            BackgroundColor = "rgba(102, 126, 234, 0.1)",
                            Tension = 0.4,
                            Fill = true
                        }
                    }
                },
                Options = new ChartOptions { Responsive = true }
            };
            await ChartInterop.InitializeChartAsync("messageTrendsChart", messageTrendsConfig);

            // Sentiment Distribution Chart
            var sentimentConfig = new ChartConfig
            {
                Type = "bar",
                Data = new ChartData
                {
                    Labels = new List<string> { "Negative", "Neutral", "Positive" },
                    Datasets = new List<ChartDataset>
                    {
                        new ChartDataset
                        {
                            Label = "Count",
                            Data = new List<double> { analytics.TotalConversations * 0.1, analytics.TotalConversations * 0.4,
analytics.TotalConversations * 0.5 },
                            BackgroundColor = new List<string> { "#dc3545", "#ffc107", "#28a745" }[0],
                            BorderColor = new List<string> { "#dc3545", "#ffc107", "#28a745" }[0]
                        }
                    }
                },
                Options = new ChartOptions { Responsive = true }
            };
            await ChartInterop.InitializeChartAsync("sentimentDistributionChart", sentimentConfig);

            // Intent Distribution Chart
            if (analytics.IntentDistribution?.Count > 0)
            {
                var intentLabels = analytics.IntentDistribution.Keys.ToList();
                var intentData = analytics.IntentDistribution.Values.Select(v => (double)v).ToList();
                var colors = new List<string> { "#667eea", "#764ba2", "#f093fb", "#4facfe", "#00f2fe" };
                var bgColors = colors.Take(intentLabels.Count).ToList();

                var intentConfig = new ChartConfig
                {
                    Type = "doughnut",
                    Data = new ChartData
                    {
                        Labels = intentLabels,
                        Datasets = new List<ChartDataset>
                        {
                            new ChartDataset
                            {
                                Data = intentData,
                                BackgroundColor = bgColors
                            }
                        }
                    },
                    Options = new ChartOptions { Responsive = true }
                };
                await ChartInterop.InitializeChartAsync("intentDistributionChart", intentConfig);
            }

            // User Activity Chart
            var userActivityConfig = new ChartConfig
            {
                Type = "bar",
                Data = new ChartData
                {
                    Labels = new List<string> { "00:00", "06:00", "12:00", "18:00", "23:59" },
                    Datasets = new List<ChartDataset>
                    {
                        new ChartDataset
                        {
                            Label = "Active Users",
                            Data = new List<double> { 10, 25, 45, 38, 20 },
                            BackgroundColor = "#764ba2"
                        }
                    }
                },
                Options = new ChartOptions { Responsive = true }
            };
            await ChartInterop.InitializeChartAsync("userActivityChart", userActivityConfig);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize charts");
        }
    }
}