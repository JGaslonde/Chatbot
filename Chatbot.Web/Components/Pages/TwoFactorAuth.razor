@page "/2fa"
@using Chatbot.Core.Models.Requests
@using Chatbot.Core.Models.Responses
@using Chatbot.Web.Services
@inject ITwoFactorManagementService TwoFactorService
@inject ILogger<TwoFactorAuth> Logger
@attribute [Authorize]

<PageTitle>Two-Factor Authentication</PageTitle>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Two-Factor Authentication (2FA)</h2>
            <p class="text-muted">Secure your account with two-factor authentication using TOTP</p>
        </div>
    </div>

    @if (loading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading 2FA settings...</span>
            </div>
        </div>
    }
    else if (setupStep == SetupStep.Display)
    {
        <div class="card">
            <div class="card-header bg-light">
                <h5>Set Up Two-Factor Authentication</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6>Step 1: Scan QR Code</h6>
                        <p>Use an authenticator app (Google Authenticator, Authy, Microsoft Authenticator) to scan this QR code:</p>
                        @if (qrCodeUrl != null)
                        {
                            <div class="text-center mb-3">
                                <img src="@qrCodeUrl" alt="QR Code" style="width: 200px; height: 200px;" />
                            </div>
                        }
                        <p class="small text-muted">Can't scan? Enter this code manually:</p>
                        <code>@setupResponse?.Secret</code>
                    </div>
                    <div class="col-md-6">
                        <h6>Step 2: Verify Code</h6>
                        <p>Enter the 6-digit code from your authenticator app:</p>
                        <div class="mb-3">
                            <input type="text" class="form-control form-control-lg" 
                                   @bind="verificationCode" 
                                   placeholder="000000" 
                                   maxlength="6"
                                   inputmode="numeric" />
                        </div>
                        <button class="btn btn-primary" @onclick="VerifyAndEnable2FA">Verify & Enable</button>
                    </div>
                </div>

                <div class="mt-4 pt-4 border-top">
                    <h6>Backup Codes</h6>
                    <p class="text-muted">Save these backup codes in a secure place. Use them if you lose access to your authenticator app.</p>
                    <div class="list-group">
                        @if (setupResponse?.BackupCodes != null)
                        {
                            @foreach (var backupCode in setupResponse.BackupCodes)
                            {
                                <div class="list-group-item"><code>@backupCode</code></div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (setupStep == SetupStep.Enabled)
    {
        <div class="alert alert-success" role="alert">
            <h4 class="alert-heading">2FA Enabled Successfully!</h4>
            <p>Your account is now protected with two-factor authentication.</p>
            <button class="btn btn-danger" @onclick="Disable2FA">Disable 2FA</button>
        </div>
    }

    @if (message != null)
    {
        <div class="alert alert-@messageType alert-dismissible fade show mt-4" role="alert">
            @message
            <button type="button" class="btn-close" @onclick="() => message = null"></button>
        </div>
    }
</div>

@code {
    private enum SetupStep { Selection, Display, Enabled }
    
    private SetupStep setupStep = SetupStep.Display;
    private TwoFactorSetupResponse? setupResponse;
    private string qrCodeUrl = "";
    private string verificationCode = "";
    private bool loading = true;
    private string? message;
    private string messageType = "info";

    protected override async Task OnInitializedAsync()
    {
        await InitializeTwoFactor();
    }

    private async Task InitializeTwoFactor()
    {
        try
        {
            setupResponse = await TwoFactorService.Setup2FAAsync();
            if (setupResponse != null)
            {
                qrCodeUrl = setupResponse.QrCodeUrl;
                setupStep = SetupStep.Display;
            }
            else
            {
                message = "Failed to initialize 2FA setup";
                messageType = "danger";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error initializing 2FA: {ex.Message}");
            message = "An error occurred while initializing 2FA";
            messageType = "danger";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task VerifyAndEnable2FA()
    {
        if (string.IsNullOrWhiteSpace(verificationCode) || setupResponse?.Secret == null)
        {
            message = "Please enter the verification code";
            messageType = "warning";
            return;
        }

        try
        {
            var success = await TwoFactorService.Enable2FAAsync(setupResponse.Secret, verificationCode);
            if (success)
            {
                message = "2FA enabled successfully";
                messageType = "success";
                setupStep = SetupStep.Enabled;
            }
            else
            {
                message = "Verification code is incorrect. Please try again.";
                messageType = "danger";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error enabling 2FA: {ex.Message}");
            message = "An error occurred while enabling 2FA";
            messageType = "danger";
        }
    }

    private async Task Disable2FA()
    {
        if (!await ConfirmAsync("Are you sure you want to disable 2FA? Your account will be less secure."))
            return;

        try
        {
            var codes = await TwoFactorService.Disable2FAAsync();
            message = "2FA has been disabled";
            messageType = "info";
            setupStep = SetupStep.Display;
            verificationCode = "";
            await InitializeTwoFactor();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error disabling 2FA: {ex.Message}");
            message = "An error occurred while disabling 2FA";
            messageType = "danger";
        }
    }

    private async Task<bool> ConfirmAsync(string message)
    {
        return await Task.FromResult(true);
    }
}
