@page "/webhooks"
@using Chatbot.Core.Models.Requests
@using Chatbot.Core.Models.Responses
@using Chatbot.Web.Services
@inject IWebhookManagementService WebhookService
@inject ILogger<Webhooks> Logger
@attribute [Authorize]

<PageTitle>Webhooks Management</PageTitle>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Webhooks Management</h2>
            <p class="text-muted">Create and manage webhooks for event notifications</p>
        </div>
        <div class="col-md-4 text-end">
            <button class="btn btn-primary" @onclick="ShowCreateForm">+ New Webhook</button>
        </div>
    </div>

    @if (showCreateForm)
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5>Create New Webhook</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label">Webhook URL</label>
                            <input type="url" class="form-control" @bind="newWebhookUrl" placeholder="https://your-domain.com/webhook" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Event Type</label>
                            <select class="form-control" @bind="newWebhookEventType">
                                <option value="message.sent">Message Sent</option>
                                <option value="message.received">Message Received</option>
                                <option value="user.login">User Login</option>
                                <option value="conversation.started">Conversation Started</option>
                                <option value="conversation.ended">Conversation Ended</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Max Retries</label>
                            <input type="number" class="form-control" @bind="newWebhookMaxRetries" min="1" max="10" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Secret Key</label>
                            <input type="password" class="form-control" @bind="newWebhookSecret" placeholder="Leave blank to auto-generate" />
                        </div>
                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" @bind="newWebhookIsActive" id="webhookActive" />
                            <label class="form-check-label" for="webhookActive">
                                Enable this webhook
                            </label>
                        </div>
                    </div>
                </div>
                <div class="btn-group">
                    <button class="btn btn-success" @onclick="CreateWebhook">Save Webhook</button>
                    <button class="btn btn-secondary" @onclick="CancelCreateForm">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (webhooks == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading webhooks...</span>
            </div>
        </div>
    }
    else if (webhooks.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No webhooks configured yet. Create your first webhook to get started.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>URL</th>
                        <th>Status</th>
                        <th>Retries</th>
                        <th>Last Triggered</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var webhook in webhooks)
                    {
                        <tr>
                            <td>@webhook.Url</td>
                            <td>
                                @if (webhook.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@webhook.EventType</td>
                            <td>@webhook.LastTriggeredAt?.ToString("g") ?? "Never"</td>
                            <td>
                                <button class="btn btn-sm btn-info" @onclick="() => EditWebhook(webhook)">Edit</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteWebhook(webhook.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (message != null)
    {
        <div class="alert alert-@messageType alert-dismissible fade show" role="alert">
            @message
            <button type="button" class="btn-close" @onclick="() => message = null"></button>
        </div>
    }
</div>

@code {
    private List<WebhookDto>? webhooks;
    private string? newWebhookUrl = "";
    private string? newWebhookSecret = "";
    private string? newWebhookEventType = "message.sent";
    private bool newWebhookIsActive = true;
    private int newWebhookMaxRetries = 3;
    private bool showCreateForm = false;
    private string? message;
    private string messageType = "info";

    protected override async Task OnInitializedAsync()
    {
        await LoadWebhooks();
    }

    private async Task LoadWebhooks()
    {
        try
        {
            webhooks = await WebhookService.GetWebhooksAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error loading webhooks: {ex.Message}");
            message = "Failed to load webhooks";
            messageType = "danger";
        }
    }

    private void ShowCreateForm()
    {
        newWebhookUrl = "";
        newWebhookSecret = "";
        newWebhookEventType = "message.sent";
        newWebhookIsActive = true;
        newWebhookMaxRetries = 3;
        showCreateForm = true;
    }

    private void CancelCreateForm()
    {
        showCreateForm = false;
    }

    private async Task CreateWebhook()
    {
        if (string.IsNullOrWhiteSpace(newWebhookUrl))
        {
            message = "Webhook URL is required";
            messageType = "warning";
            return;
        }

        var request = new WebhookRequest(
            Url: newWebhookUrl,
            Secret: newWebhookSecret,
            EventType: newWebhookEventType ?? "message.sent",
            IsActive: newWebhookIsActive,
            MaxRetries: newWebhookMaxRetries
        );

        var success = await WebhookService.CreateWebhookAsync(request) != null;
        if (success)
        {
            message = "Webhook created successfully";
            messageType = "success";
            showCreateForm = false;
            await LoadWebhooks();
        }
        else
        {
            message = "Failed to create webhook";
            messageType = "danger";
        }
    }

    private async Task EditWebhook(WebhookDto webhook)
    {
        // Placeholder for edit functionality
        message = "Edit functionality coming soon";
        messageType = "info";
    }

    private async Task DeleteWebhook(int webhookId)
    {
        if (!await ConfirmAsync("Are you sure you want to delete this webhook?"))
            return;

        var success = await WebhookService.DeleteWebhookAsync(webhookId);
        if (success)
        {
            message = "Webhook deleted successfully";
            messageType = "success";
            await LoadWebhooks();
        }
        else
        {
            message = "Failed to delete webhook";
            messageType = "danger";
        }
    }

    private async Task<bool> ConfirmAsync(string message)
    {
        // In a real app, this would use a modal dialog
        return await Task.FromResult(true);
    }
}
