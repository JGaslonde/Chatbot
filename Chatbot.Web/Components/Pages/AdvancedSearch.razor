@page "/advanced-search"
@inject HttpClient Http

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1>
                <i class="fas fa-search me-2"></i>Advanced Search
            </h1>
            <p class="text-muted">Search conversations with advanced filtering options</p>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Search Conversations</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Search Query</label>
                        <input type="text" class="form-control form-control-lg" 
                               @bind="searchQuery" 
                               placeholder="Search by content, topics, intents..."
                               @keyup="OnSearchQueryChanged">
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Filter by Topic</label>
                            <input type="text" class="form-control" 
                                   @bind="selectedTopic" 
                                   placeholder="e.g., Customer Support, Billing"
                                   @keyup="OnTopicFilterChanged">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Filter by Intent</label>
                            <input type="text" class="form-control" 
                                   @bind="selectedIntent" 
                                   placeholder="e.g., help_request, complaint"
                                   @keyup="OnIntentFilterChanged">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Sentiment Range</label>
                            <div class="input-group">
                                <input type="number" class="form-control" 
                                       @bind="sentimentMin" 
                                       min="-1" max="1" step="0.1" 
                                       placeholder="Min (-1)">
                                <span class="input-group-text">to</span>
                                <input type="number" class="form-control" 
                                       @bind="sentimentMax" 
                                       min="-1" max="1" step="0.1" 
                                       placeholder="Max (1)">
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Date Range</label>
                            <div class="input-group">
                                <input type="date" class="form-control" @bind="dateFrom">
                                <span class="input-group-text">to</span>
                                <input type="date" class="form-control" @bind="dateTo">
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="PerformSearch">
                            <i class="fas fa-search me-2"></i>Search
                        </button>
                        <button class="btn btn-secondary" @onclick="ResetFilters">
                            <i class="fas fa-redo me-2"></i>Reset
                        </button>
                        <button class="btn btn-outline-primary ms-auto" @onclick="RebuildSearchIndex">
                            <i class="fas fa-sync me-2"></i>Rebuild Index
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card bg-light">
                <div class="card-header">
                    <h5 class="mb-0">Search Tips</h5>
                </div>
                <div class="card-body">
                    <ul class="small">
                        <li><strong>Content Search:</strong> Find conversations by message content</li>
                        <li><strong>Topic Filter:</strong> Narrow by conversation topic</li>
                        <li><strong>Intent Filter:</strong> Filter by user intent</li>
                        <li><strong>Sentiment:</strong> Find positive/negative conversations</li>
                        <li><strong>Date Range:</strong> Search within specific timeframe</li>
                        <li class="mt-3"><em>Use Rebuild Index to update search data</em></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    @if (isSearching)
    {
        <div class="alert alert-info">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            Searching conversations...
        </div>
    }
    else if (searchResults != null && searchResults.Count > 0)
    {
        <div class="alert alert-info">
            Found @searchResults.Count result@(searchResults.Count != 1 ? "s" : "")
        </div>

        <div class="row">
            @foreach (var result in searchResults)
            {
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="card-subtitle text-muted">ID: @result.ConversationId</h6>
                                    <h5 class="card-title">@result.Topic</h5>
                                </div>
                                <span class="badge bg-primary">@result.Intent</span>
                            </div>

                            <p class="card-text text-truncate">@result.Snippet</p>

                            <div class="d-flex justify-content-between align-items-center small text-muted">
                                <div>
                                    <span class="badge @GetSentimentColor(result.Sentiment)">
                                        Sentiment: @result.Sentiment.ToString("F2")
                                    </span>
                                </div>
                                <div>
                                    @result.MessageDate?.ToString("g")
                                </div>
                            </div>

                            <button class="btn btn-sm btn-outline-primary mt-3" @onclick="() => ViewConversation(result.ConversationId)">
                                <i class="fas fa-eye me-1"></i>View Details
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (hasSearched && (searchResults == null || searchResults.Count == 0))
    {
        <div class="alert alert-warning">
            No conversations found matching your search criteria.
        </div>
    }
</div>

