@page "/ip-whitelist"
@using Chatbot.Core.Models.Requests
@using Chatbot.Core.Models.Responses
@using Chatbot.Web.Services
@inject IIpWhitelistManagementService WhitelistService
@inject ILogger<IpWhitelist> Logger
@attribute [Authorize]

<PageTitle>IP Whitelist Management</PageTitle>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>IP Whitelist Management</h2>
            <p class="text-muted">Restrict access to your account from specific IP addresses</p>
        </div>
        <div class="col-md-4 text-end">
            <button class="btn btn-primary" @onclick="ShowAddForm">+ Add IP Address</button>
        </div>
    </div>

    @if (showAddForm)
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5>Add IP Address to Whitelist</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label">IP Address</label>
                            <input type="text" class="form-control" @bind="newIpAddress" placeholder="192.168.1.1" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description (Optional)</label>
                            <input type="text" class="form-control" @bind="newIpDescription" placeholder="e.g., Office WiFi" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Expiration Days (Leave blank for no expiration)</label>
                            <input type="number" class="form-control" @bind="newIpExpirationDays" min="1" />
                        </div>
                    </div>
                </div>
                <div class="btn-group">
                    <button class="btn btn-success" @onclick="AddIpToWhitelist">Add IP</button>
                    <button class="btn btn-secondary" @onclick="CancelAddForm">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (ipList == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading IP whitelist...</span>
            </div>
        </div>
    }
    else if (ipList.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No IP addresses whitelisted. All IP addresses are allowed to access your account.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>IP Address</th>
                        <th>Description</th>
                        <th>Added</th>
                        <th>Expires</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ip in ipList)
                    {
                        <tr>
                            <td><code>@ip.IpAddress</code></td>
                            <td>@ip.Description</td>
                            <td>@ip.CreatedAt.ToString("g")</td>
                            <td>@(ip.ExpiresAt?.ToString("g") ?? "Never")</td>
                            <td>
                                @if (ip.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Expired</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-danger" @onclick="() => RemoveIp(ip.Id)">Remove</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (message != null)
    {
        <div class="alert alert-@messageType alert-dismissible fade show" role="alert">
            @message
            <button type="button" class="btn-close" @onclick="() => message = null"></button>
        </div>
    }
</div>

@code {
    private List<IpWhitelistDto>? ipList;
    private string? newIpAddress = "";
    private string? newIpDescription = "";
    private int? newIpExpirationDays = null;
    private bool showAddForm = false;
    private string? message;
    private string messageType = "info";

    protected override async Task OnInitializedAsync()
    {
        await LoadWhitelist();
    }

    private async Task LoadWhitelist()
    {
        try
        {
            ipList = await WhitelistService.GetWhitelistAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error loading whitelist: {ex.Message}");
            message = "Failed to load IP whitelist";
            messageType = "danger";
        }
    }

    private void ShowAddForm()
    {
        newIpAddress = "";
        newIpDescription = "";
        newIpExpirationDays = null;
        showAddForm = true;
    }

    private void CancelAddForm()
    {
        showAddForm = false;
    }

    private async Task AddIpToWhitelist()
    {
        if (string.IsNullOrWhiteSpace(newIpAddress))
        {
            message = "IP Address is required";
            messageType = "warning";
            return;
        }

        var request = new IpWhitelistRequest(
            IpAddress: newIpAddress,
            Description: newIpDescription,
            ExpirationDays: newIpExpirationDays
        );

        var success = await WhitelistService.AddIpToWhitelistAsync(request) != null;
        if (success)
        {
            message = "IP address added to whitelist";
            messageType = "success";
            showAddForm = false;
            await LoadWhitelist();
        }
        else
        {
            message = "Failed to add IP address";
            messageType = "danger";
        }
    }

    private async Task RemoveIp(int whitelistId)
    {
        if (!await ConfirmAsync("Are you sure you want to remove this IP address from the whitelist?"))
            return;

        var success = await WhitelistService.RemoveIpFromWhitelistAsync(whitelistId);
        if (success)
        {
            message = "IP address removed from whitelist";
            messageType = "success";
            await LoadWhitelist();
        }
        else
        {
            message = "Failed to remove IP address";
            messageType = "danger";
        }
    }

    private async Task<bool> ConfirmAsync(string message)
    {
        return await Task.FromResult(true);
    }
}
