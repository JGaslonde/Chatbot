@page "/analytics/audit-logs"
@using Chatbot.Core.Models.Responses
@using System.Net.Http.Json
@using Chatbot.Web.Services
@inject HttpClient Http
@inject ILogger<AuditLogsPage> Logger

<PageTitle>Audit Logs</PageTitle>

<div class="audit-container">
    <h1>System Audit Logs</h1>

    <div class="filter-section">
        <div class="form-group">
            <label>User ID</label>
            <input type="text" class="form-control" @bind="filterUserId" placeholder="Filter by user ID" />
        </div>

        <div class="form-group">
            <label>Action</label>
            <input type="text" class="form-control" @bind="filterAction" placeholder="Filter by action" />
        </div>

        <div class="form-group">
            <label>Start Date</label>
            <input type="datetime-local" class="form-control" @bind="filterStartDate" />
        </div>

        <div class="form-group">
            <label>End Date</label>
            <input type="datetime-local" class="form-control" @bind="filterEndDate" />
        </div>

        <button class="btn btn-primary" @onclick="FilterLogs">Apply Filters</button>
        <button class="btn btn-secondary" @onclick="ClearFilters">Clear Filters</button>
        <button class="btn btn-warning" @onclick="CleanupOldLogs">Cleanup Old Logs</button>
    </div>

    @if (loading)
    {
        <p><em>Loading audit logs...</em></p>
    }
    else if (logs != null && logs.Logs.Any())
    {
        <div class="logs-summary">
            <p>Showing @logs.Logs.Count of @logs.TotalCount logs (Page @logs.Page)</p>
        </div>

        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User ID</th>
                    <th>Action</th>
                    <th>Resource Type</th>
                    <th>Resource ID</th>
                    <th>Timestamp</th>
                    <th>IP Address</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in logs.Logs)
                {
                    <tr>
                        <td>@log.Id</td>
                        <td>@log.UserId</td>
                        <td>
                            <span class="badge badge-info">@log.Action</span>
                        </td>
                        <td>@log.ResourceType</td>
                        <td>@(log.ResourceId?.ToString() ?? "-")</td>
                        <td>@log.Timestamp.ToString("g")</td>
                        <td>@log.IpAddress</td>
                        <td>
                            <button class="btn btn-sm btn-info" @onclick="(() => ViewDetails(log.Id))">
                                View Details
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="pagination">
            <button class="btn btn-sm btn-outline-primary" @onclick="(() => PreviousPage())" disabled="@(logs.Page == 1)">
                Previous
            </button>
            <span>Page @logs.Page of @Math.Ceiling((double)logs.TotalCount / logs.PageSize)</span>
            <button class="btn btn-sm btn-outline-primary" @onclick="(() => NextPage())"
                    disabled="@(logs.Page* logs.PageSize >= logs.TotalCount)">
                Next
            </button>
        </div>
    }
    else if (error)
    {
        <div class="alert alert-danger">
            <p>Failed to load audit logs. Please try again.</p>
            <button class="btn btn-primary" @onclick="LoadLogs">Retry</button>
        </div>
    }
    else
    {
        <p>No audit logs found.</p>
    }
</div>

<style>
    .audit-container {
        padding: 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .filter-section {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 30px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        align-items: end;
    }

    .filter-section button {
        height: fit-content;
    }

    .logs-summary {
        margin-bottom: 20px;
        color: #666;
    }

    .pagination {
        margin-top: 20px;
        display: flex;
        justify-content: center;
        gap: 10px;
        align-items: center;
    }

    .badge {
        font-size: 12px;
        padding: 4px 8px;
    }

    .badge-info {
        background-color: #17a2b8;
        color: white;
    }
</style>

@code {
    private AuditLogResponse? logs;
    private string? filterUserId;
    private string? filterAction;
    private DateTime? filterStartDate;
    private DateTime? filterEndDate;
    private bool loading = true;
    private bool error = false;
    private int currentPage = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        try
        {
            loading = true;
            error = false;

            var url = $"api/admin/audit-logs?page={currentPage}&pageSize=50";
            if (!string.IsNullOrEmpty(filterUserId))
                url += $"&userId={filterUserId}";
            if (!string.IsNullOrEmpty(filterAction))
                url += $"&action={filterAction}";
            if (filterStartDate.HasValue)
                url += $"&startDate={filterStartDate:O}";
            if (filterEndDate.HasValue)
                url += $"&endDate={filterEndDate:O}";

            logs = await Http.GetFromJsonAsync<AuditLogResponse>(url);
            loading = false;
        }
        catch (Exception ex)
        {
            error = true;
            loading = false;
            Logger.LogError($"Error loading audit logs: {ex.Message}");
        }
    }

    private async Task FilterLogs()
    {
        currentPage = 1;
        await LoadLogs();
    }

    private async Task ClearFilters()
    {
        filterUserId = null;
        filterAction = null;
        filterStartDate = null;
        filterEndDate = null;
        currentPage = 1;
        await LoadLogs();
    }

    private void NextPage()
    {
        currentPage++;
        _ = LoadLogs();
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
            currentPage--;
        _ = LoadLogs();
    }

    private void ViewDetails(int logId)
    {
        Logger.LogInformation($"Viewing details for log {logId}");
        // In a real app, navigate to detail page or show modal
    }

    private async Task CleanupOldLogs()
    {
        try
        {
            var response = await Http.PostAsync("api/admin/audit-logs/cleanup", null);
            if (response.IsSuccessStatusCode)
            {
                await LoadLogs();
                Logger.LogInformation("Old audit logs cleaned up successfully");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error cleaning up logs: {ex.Message}");
        }
    }
}