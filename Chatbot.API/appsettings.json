{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=chatbot.db;Cache=Shared"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "",
    "Issuer": "ChatbotAPI",
    "Audience": "ChatbotClient",
    "ExpireMinutes": 1440
  },
  "RateLimiting": {
    "TrustedProxies": [],
    "AuthEndpointMaxRequests": 5,
    "GeneralEndpointMaxRequests": 100,
    "WindowMinutes": 1
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5000",
      "https://localhost:5001",
      "http://localhost:7089",
      "https://localhost:7089"
    ]
  },
  "Llm": {
    "Enabled": false,
    "Provider": "Anthropic",
    "Model": "claude-sonnet-4-6",
    "MaxContextMessages": 20
  },
  "Email": {
    "SmtpHost": "",
    "SmtpPort": 587,
    "From": "",
    "EnableSsl": true
  }
}
